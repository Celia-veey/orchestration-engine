# OpenAI配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-3.5-turbo
# 如果使用其他兼容OpenAI接口的模型服务，修改上面的BASE_URL和MODEL_NAME
# 例如：
# - Azure OpenAI: MODEL_NAME=gpt-35-turbo
# - 通义千问: MODEL_NAME=qwen-max
# - 文心一言: MODEL_NAME=ernie-4.0
# - DeepSeek: MODEL_NAME=deepseek-chat
